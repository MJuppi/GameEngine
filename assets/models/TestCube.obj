# Test Cube for Physics Testing
# Created by GameEngine Physics System
# Unit cube centered at origin with normals and texture coordinates

# Vertices
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# Normals
vn 0.0  0.0 -1.0
vn 0.0  0.0  1.0
vn 0.0 -1.0  0.0
vn 0.0  1.0  0.0
vn -1.0  0.0  0.0
vn 1.0  0.0  0.0

# Texture coordinates
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Faces - each face uses the same winding order (counter-clockwise when viewed from outside)
# Back face (z = -0.5)
f 1/1/1 2/2/1 3/3/1 4/4/1
# Front face (z = 0.5)
f 5/1/2 8/4/2 7/3/2 6/2/2
# Bottom face (y = -0.5)
f 1/1/3 4/4/3 8/4/3 5/1/3
# Top face (y = 0.5)
f 2/2/4 6/2/4 7/3/4 3/3/4
# Left face (x = -0.5)
f 1/1/5 5/1/5 7/3/5 4/4/5
# Right face (x = 0.5)
f 2/2/6 3/3/6 7/3/6 6/2/6
